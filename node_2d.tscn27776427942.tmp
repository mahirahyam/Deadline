[node name="ArcticleText1" type="RichTextLabel" parent="LaptopUI/OS_UI/TaskWindow/MarginContainer/ScrollContainer/VBoxContainer" unique_id=1633485583]
unique_name_in_owner = true
layout_mode = 2
size_flags_vertical = 3
focus_mode = 2
theme_override_colors/default_color = Color(0, 0, 0, 1)
theme_override_font_sizes/normal_font_size = 16
bbcode_enabled = true
text = "[center][b][font_size=20]ANALISIS PERFORMA WFA-kNN PADA DATASET NON-LINEAR[/font_size][/b][/center]

[fill]
Metode K-Nearest Neighbors (kNN) telah lama menjadi standar dalam klasifikasi pola, namun efektivitasnya seringkali menurun saat dihadapkan pada noise dataset yang tinggi. Dalam eksperimen ini, kami menerapkan [url=\"k1\"]metode pembobotan jarak Euclidean untuk meminimalisir dampak outlier pada akurasi final[/url]. Hasil awal menunjukkan peningkatan stabilitas sistem secara signifikan.

Permasalahan utama yang ditemukan selama pengujian adalah tingginya beban komputasi saat menangani dimensi data yang besar. [url=\"k2\"]Proses verifikasi data seringkali mengalami bottleneck pada fase kalkulasi jarak antar titik state[/url], terutama saat jumlah alfabet input meningkat secara eksponensial. Hal ini selaras dengan teori kompleksitas waktu pada mesin otomata.

Untuk memastikan hasil yang valid, tim peneliti menggunakan [url=\"k3\"]teknik 5-Fold Cross Validation yang dikombinasikan dengan matriks evaluasi presisi dan recall[/url]. Berdasarkan data tersebut, sistem deteksi ini dinyatakan siap untuk diimplementasikan pada lingkungan produksi, meskipun pengawasan manual tetap diperlukan untuk menghindari anomali transisi state yang tidak terdefinisi.
[/fill]"
horizontal_alignment = 3
vertical_alignment = 3
meta_underlined = false
selection_enabled = true

